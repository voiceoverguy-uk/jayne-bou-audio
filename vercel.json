{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/jayne-bou-audio run build",
  "outputDirectory": "artifacts/jayne-bou-audio/dist/public",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
